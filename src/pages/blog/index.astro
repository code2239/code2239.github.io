---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { buildCategoryTree, flattenTree } from "../../lib/categoryTree";
import { getTagCounts } from "../../lib/tagUtils";

const posts = await getCollection("blog");

const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const allTags = getTagCounts(posts);

const categoryNodes = flattenTree(
  buildCategoryTree(posts.map((p) => ({ categories: p.data.categories ?? [] })))
);
---

<BlogLayout allTags={allTags} totalPosts={posts.length} categoryNodes={categoryNodes}>
  <h1 class="text-3xl font-semibold mb-2">博客 <span class="text-[var(--color-text-tertiary)] text-xl font-normal">({posts.length} 篇)</span></h1>
  <p class="text-[var(--color-text-secondary)] mb-10">技术文章与思考笔记</p>

  <div class="flex flex-col gap-4">
    {sortedPosts.map((post) => (
      <div class="post-item" data-tags={post.data.tags.join(",")}>
        <ArticleCard
          title={post.data.title}
          date={post.data.date}
          summary={post.data.summary}
          tags={post.data.tags}
          href={`/blog/${post.id.replace(/\.md$/, "")}`}
        />
      </div>
    ))}
  </div>

  <p id="filter-empty" class="text-center text-[var(--color-text-tertiary)] py-12" style="display: none;">
    没有找到匹配标签的文章。
  </p>
</BlogLayout>