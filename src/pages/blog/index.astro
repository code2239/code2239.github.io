---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import PostFilter from "../../components/PostFilter.astro";

const posts = await getCollection("blog");

const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Compute tag counts
const tagCounts = new Map<string, number>();
posts.forEach((p) => p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) || 0) + 1)));
const allTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<Layout title="博客">
  <div class="px-6 xl:px-12 pt-12 pb-16">
    <h1 class="text-3xl font-semibold mb-2">博客 <span class="text-[var(--color-text-tertiary)] text-xl font-normal">({posts.length} 篇)</span></h1>
    <p class="text-[var(--color-text-secondary)] mb-10">技术文章与思考笔记</p>

    <div class="blog-list-layout">
      <!-- Left sidebar: search + tags -->
      <aside class="blog-sidebar">
        <div class="sticky top-20 space-y-6">
          <PostFilter allTags={allTags} totalPosts={posts.length} />
        </div>
      </aside>

      <!-- Right: post list -->
      <div class="blog-posts">
        <div class="flex flex-col gap-4">
          {sortedPosts.map((post) => (
            <div class="post-item" data-tags={post.data.tags.join(",")}>
              <ArticleCard
                title={post.data.title}
                date={post.data.date}
                summary={post.data.summary}
                tags={post.data.tags}
                href={`/blog/${post.id.replace(/\.md$/, "")}`}
              />
            </div>
          ))}
        </div>

        <p id="filter-empty" class="text-center text-[var(--color-text-tertiary)] py-12" style="display: none;">
          没有找到匹配标签的文章。
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .blog-list-layout { display: block; }
  .blog-sidebar { margin-bottom: 2rem; }
  .blog-posts { min-width: 0; }

  @media (min-width: 768px) {
    .blog-list-layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 3rem;
      align-items: start;
    }
    .blog-sidebar { margin-bottom: 0; }
  }
</style>