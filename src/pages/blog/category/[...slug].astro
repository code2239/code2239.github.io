---
// src/pages/blog/category/[...slug].astro
import { getCollection } from "astro:content";
import BlogLayout from "../../../layouts/BlogLayout.astro";
import Pagination from "../../../components/Pagination.astro";
import { flatCategories, buildCategoryTree, flattenTree } from "../../../lib/categoryTree";

export async function getStaticPaths() {
  const flat = flatCategories();
  return [...flat.keys()].map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const flat = flatCategories();
const cat = flat.get(slug!);

if (!cat) return Astro.redirect("/blog");

const allPosts = await getCollection("blog");
const candidateSlugs = [slug!];
for (const [s] of flat) {
  if (s.startsWith(slug! + "/")) candidateSlugs.push(s);
}

const posts = allPosts
  .filter((p) =>
    (p.data.categories ?? []).some((c) =>
      candidateSlugs.some((cs) => c === cs || c.startsWith(cs + "/"))
    )
  )
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

// Compute sidebar data from all posts (not just filtered)
const tagCounts = new Map<string, number>();
allPosts.forEach((p) => p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) || 0) + 1)));
const allTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

const categoryNodes = flattenTree(
  buildCategoryTree(allPosts.map((p) => ({ categories: p.data.categories ?? [] })))
);

const slugParts = slug!.split("/");
const breadcrumbs = slugParts.map((part, i) => {
  const href = "/blog/category/" + slugParts.slice(0, i + 1).join("/");
  const node = flat.get(slugParts.slice(0, i + 1).join("/"));
  return { label: node?.label ?? part, href };
});

const subcategories = cat.children ?? [];

// Serialize post data for client-side pagination + filtering
const postsData = posts.map((p) => ({
  title: p.data.title,
  date: p.data.date,
  summary: p.data.summary,
  tags: p.data.tags,
  href: `/blog/${p.id.replace(/\.md$/, "")}`,
}));
---

<BlogLayout title={`${cat.label} — 分类`} allTags={allTags} totalPosts={allPosts.length} categoryNodes={categoryNodes}>
  <nav class="mb-4 flex items-center gap-1.5 text-sm text-[var(--color-text-tertiary)]">
    <a href="/blog" class="no-underline hover:text-[var(--color-accent)] transition-colors">博客</a>
    {breadcrumbs.map((b, i) => (
      <>
        <span>/</span>
        {i < breadcrumbs.length - 1 ? (
          <a href={b.href} class="no-underline hover:text-[var(--color-accent)] transition-colors">{b.label}</a>
        ) : (
          <span class="text-[var(--color-text)] font-medium">{b.label}</span>
        )}
      </>
    ))}
  </nav>

  <h1 class="text-3xl font-semibold mb-2">{cat.label}</h1>
  {cat.description && (
    <p class="text-[var(--color-text-secondary)] mb-6 leading-relaxed">{cat.description}</p>
  )}

  {subcategories.length > 0 && (
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-4">子分类</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {subcategories.map((sub) => (
          <a href={`/blog/category/${slug}/${sub.slug}`} class="card-hover p-4 no-underline group">
            <h3 class="text-sm font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-1">
              {sub.label}
            </h3>
            {sub.description && (
              <p class="text-xs text-[var(--color-text-tertiary)] leading-relaxed line-clamp-2 m-0">
                {sub.description}
              </p>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <h2 class="text-lg font-semibold mb-4">文章 ({posts.length} 篇)</h2>
    {posts.length === 0 ? (
      <p class="text-[var(--color-text-tertiary)] py-8 text-center">该分类下暂无文章。</p>
    ) : (
      <div id="blog-list" class="flex flex-col gap-4">
        <p class="text-center text-[var(--color-text-tertiary)] py-4">加载中…</p>
      </div>
    )}

    <p id="filter-empty" class="text-center text-[var(--color-text-tertiary)] py-12" style="display: none;">
      没有找到匹配标签的文章。
    </p>

    <Pagination />
  </section>
</BlogLayout>

<script>
  import { createPaginator, renderPagination } from "../../../lib/list-paginator.js";
  import { renderBlogCard } from "../../../lib/card-renderers.js";

  const dataScript = document.getElementById("category-posts-data");
  const allPosts = JSON.parse(dataScript?.textContent || "[]");

  const container = document.getElementById("blog-list");
  const paginationEl = document.getElementById("pagination");
  const emptyEl = document.getElementById("filter-empty");
  const searchInput = document.getElementById("post-search");
  const clearBtn = document.getElementById("search-clear");

  const paginator = createPaginator({
    items: allPosts,
    pageSize: 10,
    filterDefs: {
      tag: (item, value) => item.tags.includes(value),
    },
    onStateChange(state) {
      if (state.pageItems.length === 0) {
        container.innerHTML = "";
        emptyEl.style.display = "block";
      } else {
        emptyEl.style.display = "none";
        container.innerHTML = state.pageItems.map(renderBlogCard).join("");
      }
      renderPagination(paginationEl, state.currentPage, state.totalPages, (page) => {
        paginator.goToPage(page);
      });
    },
  });

  window.__blogPaginator = paginator;

  // Wire up filter sidebar
  document.querySelectorAll(".sidebar-tag").forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.getAttribute("data-tag") || "";
      document.querySelectorAll(".sidebar-tag").forEach((b) =>
        b.classList.toggle("active", b === btn)
      );
      paginator.setFilter("tag", tag || "");
    });
  });

  if (searchInput) {
    searchInput.addEventListener("input", () => {
      paginator.setFilter("search", searchInput.value.trim());
      if (clearBtn) clearBtn.style.display = searchInput.value.trim() ? "flex" : "none";
    });
  }
  if (clearBtn) {
    clearBtn.addEventListener("click", () => {
      searchInput.value = "";
      searchInput.focus();
      clearBtn.style.display = "none";
      paginator.setFilter("search", "");
    });
  }

  const params = new URLSearchParams(window.location.search);
  const initTag = params.get("tag") || "";
  const initSearch = params.get("search") || "";
  if (initSearch && searchInput) {
    searchInput.value = initSearch;
    if (clearBtn) clearBtn.style.display = "flex";
  }
  if (initTag) {
    document.querySelectorAll(".sidebar-tag").forEach((b) =>
      b.classList.toggle("active", b.getAttribute("data-tag") === initTag)
    );
  }
</script>

<script type="application/json" id="category-posts-data" set:html={JSON.stringify(postsData)}></script>