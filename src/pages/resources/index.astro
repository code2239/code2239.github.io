---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import Pagination from "../../components/Pagination.astro";
import ResourceFilter from "../../features/resources/ResourceFilter.astro";
import { getTagCounts } from "../../lib/tagUtils";

const allResources = await getCollection("resources");

// Split into root-level and subdirectory groups
const rootResources: typeof allResources = [];
const groups = new Map<string, typeof allResources>();

for (const r of allResources) {
  const parts = r.id.split("/");
  if (parts.length === 1) {
    rootResources.push(r);
  } else {
    const groupName = parts[0];
    if (!groups.has(groupName)) groups.set(groupName, []);
    groups.get(groupName)!.push(r);
  }
}

const sortedRoot = rootResources.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const groupEntries = [...groups.entries()];
const allTags = getTagCounts(allResources);

// Build flat item list for pagination: groups first, then root resources
const resourceItems: Array<{
  type: "group" | "resource";
  title: string;
  date: string;
  dateRange?: string;
  summary: string;
  tags: string[];
  href: string;
  fileCount?: number;
  itemCount?: number;
}> = [];

for (const [groupName, items] of groupEntries) {
  const sorted = items.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  const dates = sorted.map((i) => i.data.date);
  const earliest = dates.sort()[0];
  const latest = dates.sort().reverse()[0];
  const allGroupTags = [...new Set(items.flatMap((i) => i.data.tags))];
  resourceItems.push({
    type: "group",
    title: groupName.replace(/-/g, " "),
    date: earliest,
    dateRange: `${earliest} ~ ${latest}`,
    summary: sorted[0]?.data.summary || "",
    tags: allGroupTags,
    href: `/resources/${groupName}`,
    itemCount: items.length,
  });
}

for (const r of sortedRoot) {
  resourceItems.push({
    type: "resource",
    title: r.data.title,
    date: r.data.date,
    summary: r.data.summary,
    tags: r.data.tags,
    href: `/resources/${r.id.replace(/\.md$/, "")}`,
    fileCount: r.data.files.length,
  });
}
---

<Layout title="资源">
  <div class="px-6 xl:px-12 pt-12 pb-16">
    <div class="blog-layout">
      <aside class="blog-sidebar">
        <div class="sticky top-20 space-y-6">
          <ResourceFilter tags={allTags} totalResources={allResources.length} />
        </div>
      </aside>

      <div class="blog-content">
        <h1 class="text-3xl font-semibold mb-2">
          资源
          {(rootResources.length + groups.size) > 0 && (
            <span class="text-[var(--color-text-tertiary)] text-xl font-normal"> ({rootResources.length + groups.size} 个)</span>
          )}
        </h1>
        <p class="text-[var(--color-text-secondary)] mb-10">公开资源与文件下载</p>

        <div id="resources-list" class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <p class="text-center text-[var(--color-text-tertiary)] py-4 col-span-2">加载中…</p>
        </div>

        <p id="resource-filter-empty" class="text-center text-[var(--color-text-tertiary)] py-12" style="display: none;">
          没有找到匹配标签的资源。
        </p>

        <Pagination />
      </div>
    </div>
  </div>
</Layout>

<style>
  .blog-layout { display: block; }
  .blog-sidebar { margin-bottom: 2rem; }
  .blog-content { min-width: 0; }

  @media (min-width: 768px) {
    .blog-layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 3rem;
      align-items: start;
    }
    .blog-sidebar { margin-bottom: 0; }
  }
</style>

<script>
  import { createPaginator, renderPagination } from "../../lib/list-paginator.js";
  import { renderResourceCard, renderResourceGroupCard } from "../../lib/card-renderers.js";

  const dataScript = document.getElementById("resources-posts-data");
  const allItems = JSON.parse(dataScript?.textContent || "[]");

  const container = document.getElementById("resources-list");
  const paginationEl = document.getElementById("pagination");
  const emptyEl = document.getElementById("resource-filter-empty");

  const paginator = createPaginator({
    items: allItems,
    pageSize: 10,
    filterDefs: {
      tag: (item, value) => item.tags.includes(value),
    },
    onStateChange(state) {
      if (state.pageItems.length === 0) {
        container.innerHTML = "";
        emptyEl.style.display = "block";
      } else {
        emptyEl.style.display = "none";
        container.innerHTML = state.pageItems
          .map((item) => (item.type === "group" ? renderResourceGroupCard(item) : renderResourceCard(item)))
          .join("");
      }
      renderPagination(paginationEl, state.currentPage, state.totalPages, (page) => {
        paginator.goToPage(page);
      });
    },
  });

  window.__resourcesPaginator = paginator;

  // Wire up filter sidebar
  document.querySelectorAll("#resource-tag-filters .sidebar-tag").forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.getAttribute("data-tag") || "";
      document.querySelectorAll("#resource-tag-filters .sidebar-tag").forEach((b) =>
        b.classList.toggle("active", b.getAttribute("data-tag") === tag)
      );
      paginator.setFilter("tag", tag || "");
    });
  });

  // Wire up tag expand button (kept inline since it's just UI toggle)
  const expandBtn = document.getElementById("resource-tag-expand-btn");
  if (expandBtn) {
    const textEl = document.getElementById("resource-tag-expand-text");
    const arrowEl = document.getElementById("resource-tag-expand-arrow");
    const collapsedTags = document.querySelectorAll(".sidebar-tag-collapsed");
    let expanded = false;
    expandBtn.addEventListener("click", () => {
      expanded = !expanded;
      collapsedTags.forEach((el) => el.classList.toggle("expanded", expanded));
      if (textEl) textEl.textContent = expanded ? "收起" : `展开全部 (${collapsedTags.length + 5} 个标签)`;
      if (arrowEl) arrowEl.classList.toggle("open", expanded);
    });
  }

  // Restore UI state from URL
  const params = new URLSearchParams(window.location.search);
  const initTag = params.get("tag") || "";
  if (initTag) {
    document.querySelectorAll("#resource-tag-filters .sidebar-tag").forEach((b) =>
      b.classList.toggle("active", b.getAttribute("data-tag") === initTag)
    );
  }
</script>

<script type="application/json" id="resources-posts-data" set:html={JSON.stringify(resourceItems)}></script>