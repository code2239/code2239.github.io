---
import Layout from "../../layouts/ProjectLayout.astro";
import fs from "fs";
import path from "path";

const PROJECT_DIR = "src/content/projects/jingangshi-jueyuanhua";

interface FileNode {
  name: string;
  webPath: string;
  isDir: boolean;
  children: FileNode[];
  size: string;
  ext: string;
}

function scanDir(dirPath: string, webBase: string): FileNode[] {
  let entries: fs.Dirent[];
  try { entries = fs.readdirSync(dirPath, { withFileTypes: true }); }
  catch { return []; }
  return entries
    .filter(e => !e.name.startsWith("."))
    .sort((a, b) => {
      if (a.isDirectory() !== b.isDirectory()) return a.isDirectory() ? -1 : 1;
      return a.name.localeCompare(b.name);
    })
    .map(e => {
      const full = path.join(dirPath, e.name);
      const web = webBase + "/" + e.name;
      if (e.isDirectory()) {
        return { name: e.name, webPath: web, isDir: true, children: scanDir(full, web), size: "", ext: "" };
      }
      let size = ""; try { const s = fs.statSync(full).size; size = s < 1024 ? s + " B" : s < 1048576 ? (s/1024).toFixed(1) + " KB" : (s/1048576).toFixed(1) + " MB"; } catch {}
      const ext = e.name.endsWith(".pdf") ? "pdf" : e.name.endsWith(".md") ? "md" : e.name.endsWith(".py") ? "py" : "";
      return { name: e.name, webPath: web, isDir: false, children: [], size, ext };
    });
}

const tree = scanDir(PROJECT_DIR, "/projects/jingangshi-jueyuanhua");

function renderTree(nodes: FileNode[], depth: number): string {
  if (!nodes.length) return "";
  let html = '<ul class="tree-ul" style="padding-left:' + (depth === 0 ? 0 : 1.25) + 'rem">';
  for (const node of nodes) {
    const hasChildren = node.children.length > 0;
    if (node.isDir) {
      html += '<li class="tree-li' + (hasChildren ? '' : ' collapsed') + '">';
      html += '<div class="tree-row">';
      if (hasChildren) {
        html += '<button class="tree-toggle" onclick="this.closest(\'li\').classList.toggle(\'collapsed\')" aria-label="展开/折叠">';
        html += '<svg width="8" height="8" viewBox="0 0 8 8"><path d="M2 0 L6 4 L2 8" fill="currentColor"/></svg>';
        html += '</button>';
      } else {
        html += '<span class="tree-toggle"></span>';
      }
      html += '<span class="tree-icon">📁</span>';
      html += '<span class="tree-dir-name">' + escapeHtml(node.name) + '</span>';
      if (hasChildren) {
        html += '<span class="tree-badge">' + node.children.length + '</span>';
      }
      html += '</div>';
      html += renderTree(node.children, depth + 1);
      html += '</li>';
    } else {
      html += '<li class="tree-li"><div class="tree-row">';
      html += '<span class="tree-toggle"></span>';
      const icon = node.ext === "pdf" ? "📄" : node.ext === "md" ? "📝" : node.ext === "py" ? "🐍" : "📄";
      html += '<span class="tree-icon">' + icon + '</span>';
      html += '<a class="tree-name" href="' + node.webPath + '">' + escapeHtml(node.name) + '</a>';
      if (node.ext) html += '<span class="tree-badge tree-badge-' + node.ext + '">' + node.ext.toUpperCase() + '</span>';
      if (node.size) html += '<span class="tree-size">' + node.size + '</span>';
      html += '</div></li>';
    }
  }
  html += '</ul>';
  return html;
}

function escapeHtml(s: string): string {
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

const treeHtml = renderTree(tree, 0);
---

<Layout title="金刚石绝缘化" date="2026-07-07" tags={["金刚石", "半导体", "绝缘化", "MPCVD"]} backHref="/projects" backLabel="返回项目列表">
  <div class="mb-8">
    <p class="text-[var(--color-text-secondary)] leading-relaxed">
      金刚石/硅异质集成绝缘化技术深度调研项目。覆盖低温 MPCVD 生长、Diamane（双层金刚石烯）、单晶膜键合三大技术路线。
    </p>
    <p class="text-sm text-[var(--color-text-tertiary)] mt-3">
      以下列出项目全部文件（保持原始文件夹结构）。点击文件名即可直接阅读，左侧自动显示项目文件导航。
    </p>
  </div>

  <div class="flex items-center justify-between mb-3">
    <h2 class="text-lg font-semibold">📁 项目文件</h2>
    <button
      class="toggle-all text-xs text-[var(--color-text-tertiary)] bg-[var(--color-bg-secondary)] border border-[var(--color-border)] px-2.5 py-1 rounded hover:text-[var(--color-accent)] cursor-pointer"
      onclick="this.closest('.file-tree-wrapper').querySelector('.file-tree').classList.toggle('all-collapsed')"
    >
      展开/折叠全部
    </button>
  </div>

  <div class="file-tree-wrapper">
    <div class="file-tree border border-[var(--color-border)] rounded-lg overflow-hidden">
      <Fragment set:html={treeHtml} />
    </div>
  </div>
</Layout>

<style>
  .file-tree {
    background: var(--color-bg-secondary);
    padding: 0.25rem 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .file-tree ul { list-style: none; margin: 0; padding: 0; }
  .file-tree .tree-ul { margin: 0; }
  .tree-li { margin: 0; }
  .tree-li.collapsed > .tree-ul { display: none; }
  .tree-li.collapsed > .tree-row > .tree-toggle svg { transform: rotate(0deg); }

  .tree-row {
    display: flex;
    align-items: center;
    padding: 0.18rem 0.75rem;
    gap: 0.3rem;
    transition: background 0.1s;
    line-height: 1.8;
  }
  .tree-row:hover { background: var(--color-bg-tertiary); }

  .tree-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }
  .tree-toggle svg { 
    transition: transform 0.12s ease;
    transform: rotate(90deg);
  }

  .tree-icon { flex-shrink: 0; font-size: 0.85rem; }
  .tree-name {
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }
  .tree-name:hover { color: var(--color-accent); text-decoration: underline; }
  .tree-dir-name {
    color: var(--color-text-secondary);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .tree-badge {
    font-size: 0.6rem;
    padding: 0.05rem 0.3rem;
    border-radius: 2px;
    font-weight: 600;
    flex-shrink: 0;
  }
  .tree-badge.pdf { background: var(--color-accent-soft); color: var(--color-accent); }
  .tree-badge.md   { background: #f0fdf4; color: #166534; }
  .tree-badge.py   { background: #fef9e7; color: #8b6914; }

  .tree-size {
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .file-tree.all-collapsed .tree-li { }
  .file-tree.all-collapsed .tree-li.collapsed { }
</style>
