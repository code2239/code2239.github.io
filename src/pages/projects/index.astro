---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import Pagination from "../../components/Pagination.astro";

const allProjects = await getCollection("projects");

// Split into root-level and subdirectory entries
const rootProjects: typeof allProjects = [];
const groups = new Map<string, typeof allProjects>();

for (const p of allProjects) {
  const parts = p.id.split("/");
  if (parts.length === 1) {
    rootProjects.push(p);
  } else {
    const groupName = parts[0];
    if (!groups.has(groupName)) groups.set(groupName, []);
    groups.get(groupName)!.push(p);
  }
}

const sortedRoot = rootProjects.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const groupEntries = [...groups.entries()];

// Build flat item list for pagination
const projectItems: Array<{
  type: "group" | "project";
  title: string;
  date: string;
  dateRange?: string;
  summary: string;
  tags: string[];
  href: string;
  image?: string;
  github?: string;
  demo?: string;
  itemCount?: number;
}> = [];

for (const [groupName, items] of groupEntries) {
  const sorted = items.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  const dates = sorted.map((i) => i.data.date);
  const earliest = dates.sort()[0];
  const latest = dates.sort().reverse()[0];
  const allGroupTags = [...new Set(items.flatMap((i) => i.data.tags))].slice(0, 5);
  projectItems.push({
    type: "group",
    title: groupName.replace(/-/g, " "),
    date: earliest,
    dateRange: `${earliest} ~ ${latest}`,
    summary: sorted[0]?.data.summary || "",
    tags: allGroupTags,
    href: `/projects/${groupName}`,
    itemCount: items.length,
  });
}

for (const p of sortedRoot) {
  projectItems.push({
    type: "project",
    title: p.data.title,
    date: p.data.date,
    summary: p.data.summary,
    tags: p.data.tags,
    href: `/projects/${p.id.replace(/\.md$/, "")}`,
    image: p.data.image,
    github: p.data.github,
    demo: p.data.demo,
  });
}
---

<Layout title="项目">
  <div class="px-6 xl:px-12 pt-12 pb-16">
    <div class="max-w-content">
      <h1 class="text-3xl font-semibold mb-2">
        项目
        {(rootProjects.length + groups.size) > 0 && (
          <span class="text-[var(--color-text-tertiary)] text-xl font-normal"> ({rootProjects.length + groups.size} 个)</span>
        )}
      </h1>
      <p class="text-[var(--color-text-secondary)] mb-10">项目作品展示</p>

      <div id="projects-list" class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <p class="text-center text-[var(--color-text-tertiary)] py-4 col-span-2">加载中…</p>
      </div>

      <Pagination />
    </div>
  </div>
</Layout>

<script>
  import { createPaginator, renderPagination } from "../../lib/list-paginator.js";
  import { renderProjectCard } from "../../lib/card-renderers.js";

  const dataScript = document.getElementById("projects-posts-data");
  const allItems = JSON.parse(dataScript?.textContent || "[]");

  const container = document.getElementById("projects-list");
  const paginationEl = document.getElementById("pagination");

  const paginator = createPaginator({
    items: allItems,
    pageSize: 10,
    filterDefs: {},
    onStateChange(state) {
      container.innerHTML = state.pageItems.map(renderProjectCard).join("");
      renderPagination(paginationEl, state.currentPage, state.totalPages, (page) => {
        paginator.goToPage(page);
      });
    },
  });

  window.__projectsPaginator = paginator;
</script>

<script type="application/json" id="projects-posts-data" set:html={JSON.stringify(projectItems)}></script>