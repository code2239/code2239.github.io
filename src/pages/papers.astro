---
import Layout from "../components/Layout.astro";

const papers = [
  { date: "2026-07-05", title: "7月5日 论文阅读日报", file: "papers_2026-07-05.html" },
  { date: "2026-07-04", title: "7月4日 论文阅读日报", file: "papers_2026-07-04.html" },
  { date: "2026-07-03", title: "7月3日 论文阅读日报", file: "papers_2026-07-03.html" },
  { date: "2026-07-02", title: "7月2日 论文阅读日报", file: "papers_2026-07-02.html" },
];
---

<Layout title="论文阅读">
  <div class="max-w-content py-16">
    <h1 class="text-3xl font-semibold mb-2">论文阅读</h1>
    <p class="text-[var(--color-text-secondary)] mb-12">每日 AI 论文阅读与笔记</p>

    <div class="flex flex-col gap-4">
      {papers.map((paper) => (
        <article class="card-hover border border-[var(--color-border)] rounded-xl p-6 bg-[var(--color-bg)]">
          <a href={`/papers/${paper.file}`} class="no-underline block group">
            <h3 class="text-lg font-semibold mb-1.5 text-[var(--color-text)]">
              {paper.title}
            </h3>
            <p class="text-sm text-[var(--color-text-tertiary)]">{paper.date}</p>
          </a>
        </article>
      ))}
    </div>
  </div>
</Layout>
