---
import Layout from "../components/Layout.astro";
import { siteConfig } from "../lib/config";
---

<Layout title="关于">
  <div class="max-w-content py-16">
    <h1 class="text-3xl font-semibold mb-2">关于</h1>
    <p class="text-[var(--color-text-secondary)] mb-12">关于我和这个网站</p>

    <section class="mb-14">
      <h2 class="text-lg font-semibold mb-4">关于我</h2>
      <div class="card-hover p-6">
        <p class="text-[var(--color-text-secondary)] leading-relaxed">
          你好，我是<strong class="text-[var(--color-text)]">星游寰宇</strong>，这是我的个人网站，专注于探索 <strong class="text-[var(--color-text)]">AI Agent 协作</strong>、<strong class="text-[var(--color-text)]">AI技术分享</strong> 以及 <strong class="text-[var(--color-text)]">个人的学习笔记</strong>。
        </p>
      </div>
    </section>

    <section>
      <h2 class="text-lg font-semibold mb-4">联系</h2>
      <div class="card-hover p-6 flex flex-col gap-3">
        <a href={siteConfig.social.github} class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-accent)] transition-colors" target="_blank" rel="noopener noreferrer">
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          {siteConfig.social.github.replace("https://github.com/", "@")}
        </a>
        <a href={`mailto:${siteConfig.social.email}`} class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-accent)] transition-colors">
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {siteConfig.social.email}
        </a>
      </div>
    </section>
  </div>
</Layout>