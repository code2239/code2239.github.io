---
import Layout from "../components/Layout.astro";
import { siteConfig } from "../lib/config";

const skills = [
  "Claude Code",
  "Agent Orchestration",
  "TypeScript",
  "Python",
  "Astro",
  "React",
  "Tailwind CSS",
  "GitHub Actions",
  "Multi-Agent Systems",
  "LLM Application Design",
];
---

<Layout title="关于">
  <div class="max-w-content py-16">
    <h1 class="text-3xl font-semibold mb-8">关于</h1>

    <section class="mb-12">
      <h2 class="text-lg font-semibold mb-3">关于我</h2>
      <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-xl">
        你好，我是星游寰宇。我专注于探索 AI Agent 协作、软件工程工具链
        以及人机交互的新范式。这个网站记录了我的技术思考、项目实践与学习笔记。
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-lg font-semibold mb-3">技能</h2>
      <div class="flex flex-wrap gap-2 max-w-xl">
        {skills.map((skill) => (
          <span class="text-sm text-[var(--color-text-secondary)] bg-[var(--color-bg-secondary)] border border-[var(--color-border)] px-3 py-1 rounded-full">
            {skill}
          </span>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-lg font-semibold mb-3">联系</h2>
      <div class="flex flex-col gap-2 text-[var(--color-text-secondary)] max-w-xl">
        <p>
          GitHub:{" "}
          <a
            href={siteConfig.social.github}
            class="text-[var(--color-text)] underline-offset-4"
          >
            {siteConfig.social.github.replace("https://github.com/", "@")}
          </a>
        </p>
        <p>
          Email:{" "}
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="text-[var(--color-text)] underline-offset-4"
          >
            {siteConfig.social.email}
          </a>
        </p>
      </div>
    </section>
  </div>
</Layout>
