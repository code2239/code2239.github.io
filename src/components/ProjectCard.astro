---
import TagList from "./TagList.astro";

interface Props {
  name: string;
  description: string;
  tags: string[];
  url: string;
}

const { name, description, tags, url } = Astro.props;
---

<article class="card-hover border border-[var(--color-border)] rounded-xl p-6 bg-[var(--color-bg)]">
  <a href={url} class="no-underline block group">
    <h3 class="text-lg font-semibold mb-1.5 text-[var(--color-text)]">
      {name}
    </h3>
    <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed mb-3">
      {description}
    </p>
    <TagList tags={tags} />
  </a>
</article>
