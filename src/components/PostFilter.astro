---
// Blog sidebar: composes search, category nav, and tag filter.
// To remove a feature: delete its import + its folder in src/features/blog/
import type { FlatNode } from "../lib/categoryTree";
import BlogSearch from "../features/blog/BlogSearch.astro";
import CategoryNav from "../features/blog/CategoryNav.astro";
import TagFilter from "../features/blog/TagFilter.astro";

interface TagEntry {
  0: string;
  1: number;
}

interface Props {
  allTags: TagEntry[];
  totalPosts: number;
  categoryNodes: FlatNode[];
}

const { allTags, totalPosts, categoryNodes } = Astro.props;
---

<BlogSearch />
<CategoryNav nodes={categoryNodes} />
<TagFilter tags={allTags} totalPosts={totalPosts} />

<script>
  import { initFilter } from '../features/blog/filter-controller.js';

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFilter);
  } else {
    initFilter();
  }
</script>
