---
import TagList from "./TagList.astro";

interface Props {
  title: string;
  date: string;
  summary: string;
  tags: string[];
  href: string;
}

const { title, date, summary, tags, href } = Astro.props;
---

<article class="card-hover p-6">
  <a href={href} class="no-underline block group">
    <h3 class="text-lg font-semibold mb-1.5 text-[var(--color-text)]">
      {title}
    </h3>
    <p class="text-sm text-[var(--color-text-tertiary)] mb-2">{date}</p>
    <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed mb-3 line-clamp-2">
      {summary}
    </p>
    <TagList tags={tags} />
  </a>
</article>
