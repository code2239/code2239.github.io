---
import Layout from "../components/Layout.astro";
import TagList from "../components/TagList.astro";

interface Props {
  title: string;
  date: string;
  tags: string[];
}

const { title, date, tags } = Astro.props;
---

<Layout title={title}>
  <article class="max-w-content py-16">
    <header class="mb-12 text-center">
      <h1 class="text-3xl font-semibold mb-3">{title}</h1>
      <div class="flex items-center justify-center gap-2 text-[var(--color-text-tertiary)] text-sm">
        <time datetime={date}>{date}</time>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <TagList tags={tags} />
          </>
        )}
      </div>
    </header>

    <div>
      <slot />
    </div>

    <hr />

    <div class="mt-8">
      <a
        href="/blog"
        class="text-sm text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-text)] transition-colors duration-150"
      >
        &larr; 返回博客列表
      </a>
    </div>
  </article>
</Layout>
