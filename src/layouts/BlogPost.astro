---
import Layout from "../components/Layout.astro";
import TagList from "../components/TagList.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ReadingProgress from "../features/blog/ReadingProgress.astro";
import BackToTop from "../features/blog/BackToTop.astro";
import CopyButton from "../features/blog/CopyButton.astro";

interface PostLink {
  title: string;
  href: string;
}

interface Props {
  title: string;
  date: string;
  tags: string[];
  headings?: { depth: number; slug: string; text: string }[];
  wordCount?: number;
  prevPost?: PostLink | null;
  nextPost?: PostLink | null;
}

const { title, date, tags, headings = [], wordCount = 0, prevPost, nextPost } = Astro.props;
const readingTime = Math.max(1, Math.ceil(wordCount / 300));
const hasToc = headings.length > 0;
---

<Layout title={title}>
  <ReadingProgress />

  <BackToTop />
  <CopyButton />

  <div class="px-6 xl:px-12 pt-12 pb-16">
    <article>
      <header class="mb-12 text-center">
        <h1 class="text-3xl font-semibold mb-3 tracking-tight">{title}</h1>
        <div class="flex items-center justify-center gap-2 text-[var(--color-text-tertiary)] text-sm">
          <time datetime={date}>{date}</time>
          <span class="text-[var(--color-border)]">·</span>
          <span>{readingTime} 分钟阅读</span>
          {tags.length > 0 && (
            <>
              <span class="text-[var(--color-border)]">·</span>
              <TagList tags={tags} />
            </>
          )}
        </div>
      </header>

      <div class="blog-layout">
        {
          hasToc && (
            <aside class="blog-toc">
              <div class="sticky top-24">
                <TableOfContents headings={headings} />
              </div>
            </aside>
          )
        }

        <div class="blog-body">
          <div class="prose prose-neutral max-w-none">
            <slot />
          </div>

          <!-- Previous / Next navigation -->
          {(prevPost || nextPost) && (
            <nav class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-12 pt-8 border-t border-[var(--color-border)]">
              {prevPost ? (
                <a href={prevPost.href} class="card-hover p-4 no-underline group">
                  <span class="text-xs text-[var(--color-text-tertiary)] block mb-1">&larr; 上一篇</span>
                  <span class="text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors line-clamp-1">{prevPost.title}</span>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={nextPost.href} class="card-hover p-4 no-underline group text-right">
                  <span class="text-xs text-[var(--color-text-tertiary)] block mb-1">下一篇 &rarr;</span>
                  <span class="text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors line-clamp-1">{nextPost.title}</span>
                </a>
              ) : <div />}
            </nav>
          )}

          <hr class="!mt-12 !mb-8" />

          <div>
            <a
              href="/blog"
              class="text-sm text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-text)] transition-colors duration-150"
            >
              &larr; 返回博客列表
            </a>
          </div>
        </div>
      </div>
    </article>
  </div>
</Layout>

<style>
  .blog-layout { display: block; }
  .blog-toc { display: none; }
  .blog-body { min-width: 0; }
  @media (min-width: 1024px) {
    .blog-layout { display: grid; grid-template-columns: 14rem 1fr; gap: 3rem; align-items: start; }
    .blog-toc { display: block; }
    .blog-body { padding-right: 2rem; }
  }

</style>

<script>
  // --- TOC highlight ---
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-list a");
  if (tocLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => {
              link.classList.toggle("active", link.getAttribute("href") === `#${entry.target.id}`);
            });
          }
        }
      },
      { rootMargin: "-80px 0px -80% 0px" }
    );
    tocLinks.forEach((link) => {
      const id = link.getAttribute("href")?.slice(1);
      if (id) { const target = document.getElementById(id); if (target) observer.observe(target); }
    });
  }

</script>