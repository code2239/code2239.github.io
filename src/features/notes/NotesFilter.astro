---
import "../../styles/calendar-theme.css";

interface TagEntry {
  0: string;
  1: number;
}

interface Props {
  allTags: TagEntry[];
  totalNotes: number;
  categoryCounts: Record<string, number>;
  noteDates: string[];
}

const { allTags, totalNotes, categoryCounts, noteDates } = Astro.props;

const categories = [
  { value: "", label: "全部", count: totalNotes },
  { value: "reading", label: "读书笔记", count: categoryCounts.reading || 0 },
  { value: "learning", label: "学习笔记", count: categoryCounts.learning || 0 },
  { value: "research", label: "研究记录", count: categoryCounts.research || 0 },
];
---

<div class="space-y-5">
  <!-- Category filter -->
  <div>
    <h3 class="text-xs font-semibold text-[var(--color-text-tertiary)] uppercase tracking-wider mb-2">笔记类型</h3>
    <div class="flex flex-wrap gap-1.5">
      {categories.map((cat) => (
        <button
          class={`note-cat-btn text-xs px-2.5 py-1 rounded-full bg-transparent text-[var(--color-text-secondary)] border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors cursor-pointer ${
            cat.value === "" ? "active" : ""
          }`}
          data-category={cat.value}
        >
          {cat.label} ({cat.count})
        </button>
      ))}
    </div>
  </div>

  <!-- Calendar -->
  <div>
    <h3 class="text-xs font-semibold text-[var(--color-text-tertiary)] uppercase tracking-wider mb-2">日期</h3>
    <div id="notes-calendar" data-dates={noteDates.join(",")}></div>
    <button id="cal-clear" class="mt-2 text-[10px] text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] transition-colors hidden">清除日期筛选</button>
  </div>

  <!-- Tag filter -->
  <div>
    <h3 class="text-xs font-semibold text-[var(--color-text-tertiary)] uppercase tracking-wider mb-2">标签</h3>
    <div class="flex flex-wrap gap-1.5">
      {allTags.map(([tag, count]) => (
        <button
          class="note-tag-btn text-xs px-2.5 py-1 rounded-full bg-transparent border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors cursor-pointer"
          data-tag={tag}
        >
          {tag} ({count})
        </button>
      ))}
    </div>
  </div>
</div>

<style>
  .note-cat-btn.active,
  .note-tag-btn.active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  /* color-calendar theme — CSS custom properties */
  :global(:root) {
    --cal-color-primary: var(--color-accent);
    --cal-font-family-header: var(--font-sans);
    --cal-font-family-weekdays: var(--font-sans);
    --cal-font-family-body: var(--font-sans);
  }

  /* calendar container tweaks */
  :global(#notes-calendar) {
    width: 100%;
  }
  :global(#notes-calendar .color-calendar) {
    background: transparent;
  }
  :global(#notes-calendar .calendar__header) {
    color: var(--color-text-tertiary);
  }
  :global(#notes-calendar .calendar__monthyear) {
    font-size: 13px;
    color: var(--color-text);
  }
  :global(#notes-calendar .calendar__day) {
    font-size: 11px;
    font-weight: 300;
    color: var(--color-text);
  }
  /* prev/next month → extra faint */
  :global(#notes-calendar .calendar__day.prev-month),
  :global(#notes-calendar .calendar__day.next-month) {
    color: color-mix(in srgb, var(--color-text-tertiary) 25%, transparent);
  }
  /* has event → bold accent */
  :global(#notes-calendar .calendar__day.has-event) {
    font-weight: 700;
    color: var(--color-accent);
  }
  /* arrows */
  :global(#notes-calendar .calendar__arrow) {
    opacity: 0.5;
  }
  :global(#notes-calendar .calendar__arrow:hover) {
    opacity: 0.8;
  }
  :global(#notes-calendar .calendar__event-bullet) {
    display: none;
  }
</style>

<script>
  async function initNotesFilter() {
    const catBtns = document.querySelectorAll<HTMLButtonElement>(".note-cat-btn");
    const tagBtns = document.querySelectorAll<HTMLButtonElement>(".note-tag-btn");
    const items = document.querySelectorAll<HTMLElement>(".note-item");
    const emptyEl = document.getElementById("notes-filter-empty");

    let activeCategory = "";
    let activeTag = "";
    let activeDate = "";

    function updateVisibility() {
      let visibleCount = 0;
      items.forEach((item) => {
        const itemCategory = item.getAttribute("data-category") || "";
        const itemTags = item.getAttribute("data-tags") || "";
        const itemDate = item.getAttribute("data-date") || "";
        const catMatch = !activeCategory || itemCategory === activeCategory;
        const tagMatch = !activeTag || itemTags.split(",").includes(activeTag);
        const dateMatch = !activeDate || itemDate === activeDate;
        if (catMatch && tagMatch && dateMatch) {
          item.style.display = "";
          visibleCount++;
        } else {
          item.style.display = "none";
        }
      });
      if (emptyEl) emptyEl.style.display = visibleCount === 0 ? "block" : "none";
    }

    catBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeCategory = btn.getAttribute("data-category") || "";
        catBtns.forEach((b) => b.classList.toggle("active", b.getAttribute("data-category") === activeCategory));
        const url = new URL(window.location.href);
        activeCategory ? url.searchParams.set("category", activeCategory) : url.searchParams.delete("category");
        window.history.replaceState({}, "", url.toString());
        updateVisibility();
      });
    });

    tagBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tag = btn.getAttribute("data-tag") || "";
        if (activeTag === tag) {
          activeTag = "";
          tagBtns.forEach((b) => b.classList.remove("active"));
        } else {
          activeTag = tag;
          tagBtns.forEach((b) => b.classList.toggle("active", b.getAttribute("data-tag") === activeTag));
        }
        const url = new URL(window.location.href);
        activeTag ? url.searchParams.set("tag", activeTag) : url.searchParams.delete("tag");
        window.history.replaceState({}, "", url.toString());
        updateVisibility();
      });
    });

    // ===== color-calendar =====
    const calRoot = document.getElementById("notes-calendar")!;
    const calClear = document.getElementById("cal-clear")!;
    const rawDates: string[] = (calRoot.dataset.dates || "").split(",").filter((d) => d);

    const { default: Calendar } = await import("color-calendar");

    const initialDate = activeDate ? new Date(activeDate + "T00:00:00") : null;

    const calendar = new Calendar({
      container: calRoot,
      theme: "basic",
      primaryColor: getComputedStyle(document.documentElement).getPropertyValue("--color-accent").trim(),
      headerColor: getComputedStyle(document.documentElement).getPropertyValue("--color-text").trim(),
      headerBackgroundColor: "transparent",
      weekdaysColor: getComputedStyle(document.documentElement).getPropertyValue("--color-text-tertiary").trim(),
      weekdayDisplayType: "long-lower",
      startWeekday: 1,  // Monday
      borderRadius: "0.5rem",
      fontFamilyBody: getComputedStyle(document.documentElement).getPropertyValue("--font-sans").trim(),
      fontFamilyHeader: getComputedStyle(document.documentElement).getPropertyValue("--font-sans").trim(),
      fontFamilyWeekdays: getComputedStyle(document.documentElement).getPropertyValue("--font-sans").trim(),
      disableMonthYearPickers: true,
      eventsData: rawDates.map((d) => ({ start: d })),
      selectedDate: initialDate,
      onSelectedDateClick(currentDate: Date | undefined) {
        if (!currentDate) return;
        const y = currentDate.getFullYear();
        const m = String(currentDate.getMonth() + 1).padStart(2, "0");
        const d = String(currentDate.getDate()).padStart(2, "0");
        const ds = `${y}-${m}-${d}`;
        const previousDate = calendar.getSelectedDate();
        if (previousDate) {
          const py = previousDate.getFullYear();
          const pm = String(previousDate.getMonth() + 1).padStart(2, "0");
          const pd = String(previousDate.getDate()).padStart(2, "0");
          const ps = `${py}-${pm}-${pd}`;
          if (ds === ps) {
            // Toggle off
            activeDate = "";
            calendar.setSelectedDate(null);
            calClear.classList.add("hidden");
            const url = new URL(window.location.href);
            url.searchParams.delete("date");
            window.history.replaceState({}, "", url.toString());
            updateVisibility();
            return;
          }
        }
        activeDate = ds;
        calClear.classList.remove("hidden");
        const url = new URL(window.location.href);
        url.searchParams.set("date", ds);
        window.history.replaceState({}, "", url.toString());
        updateVisibility();
      },
    });

    calClear.addEventListener("click", () => {
      activeDate = "";
      calendar.setSelectedDate(null);
      calClear.classList.add("hidden");
      const url = new URL(window.location.href);
      url.searchParams.delete("date");
      window.history.replaceState({}, "", url.toString());
      updateVisibility();
    });

    if (rawDates.length > 0 && !activeDate) {
      // Navigate to newest note's month
      const newest = new Date([...rawDates].sort().reverse()[0] + "T00:00:00");
      calendar.currentViewDate = newest;
      calendar.updateCalendar(true);
    }

    // Handle initial URL params
    const params = new URLSearchParams(window.location.search);
    const iCat = params.get("category") || "";
    const iTag = params.get("tag") || "";
    const iDate = params.get("date") || "";
    if (iCat) {
      activeCategory = iCat;
      catBtns.forEach((b) => b.classList.toggle("active", b.getAttribute("data-category") === activeCategory));
    }
    if (iDate) {
      activeDate = iDate;
      const d = new Date(iDate + "T00:00:00");
      calendar.setSelectedDate(d);
      calendar.currentViewDate = d;
      calendar.updateCalendar(true);
      calClear.classList.remove("hidden");
    }
    if (iTag) {
      activeTag = iTag;
      tagBtns.forEach((b) => b.classList.toggle("active", b.getAttribute("data-tag") === activeTag));
    }
    updateVisibility();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNotesFilter);
  } else {
    initNotesFilter();
  }
</script>
