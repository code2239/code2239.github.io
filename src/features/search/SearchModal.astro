---
// SearchModal.astro — Orama-powered global search overlay
// Fetches pre-built /search-index.json, searches with @orama/orama client-side.
---

<div id="search-overlay" class="srch-overlay" role="dialog" aria-modal="true" aria-label="全局搜索">
  <div id="search-backdrop" class="srch-backdrop"></div>
  <div class="srch-panel" id="srch-panel">
    <!-- Search input -->
    <div class="srch-input-row">
      <svg class="srch-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input
        type="text"
        id="search-input"
        class="srch-input"
        placeholder="搜索文章、项目、日记、资源..."
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        enterkeyhint="go"
      />
      <kbd class="srch-kbd">Esc</kbd>
    </div>

    <!-- Results area -->
    <div id="search-results" class="srch-results">
      <p class="srch-empty" id="search-empty-hint">输入关键词开始搜索</p>
    </div>

    <!-- Skeleton loading -->
    <div id="search-skeleton" class="srch-skeleton" style="display:none;" aria-hidden="true">
      <div class="srch-skeleton-line" style="width:75%"></div>
      <div class="srch-skeleton-line" style="width:50%"></div>
      <div class="srch-skeleton-line" style="width:60%"></div>
    </div>

    <!-- Footer hints -->
    <div class="srch-footer">
      <div class="srch-footer-hints">
        <span><kbd>↑</kbd><kbd>↓</kbd> 导航</span>
        <span><kbd>↵</kbd> 打开</span>
        <span><kbd>Ctrl</kbd>+<kbd>K</kbd> 切换</span>
      </div>
      <div class="srch-footer-brand">
        powered by Orama
      </div>
    </div>
  </div>
</div>

<style>
  /* ==============================
     Search Overlay
     ============================== */
  .srch-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding: 5rem 1rem 2rem;
  }
  .srch-overlay.open {
    display: flex;
  }

  .srch-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(12px) saturate(120%);
    -webkit-backdrop-filter: blur(12px) saturate(120%);
  }

  /* ==============================
     Panel
     ============================== */
  .srch-panel {
    position: relative;
    width: 100%;
    max-width: 640px;
    max-height: 80vh;
    background: rgba(252, 252, 249, 0.88);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 16px;
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.04),
      0 4px 32px rgba(0, 0, 0, 0.1),
      0 16px 64px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ==============================
     Input Row
     ============================== */
  .srch-input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.125rem;
    border-bottom: 1px solid var(--color-border);
    position: relative;
    transition: background 200ms ease, box-shadow 200ms ease;
  }
  .srch-input-row:focus-within {
    box-shadow: inset 0 -2px 0 var(--color-accent);
    background: rgba(238, 243, 252, 0.3);
  }

  .srch-input-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
    transition: color 200ms ease, filter 200ms ease;
  }
  .srch-input-row:focus-within .srch-input-icon {
    color: var(--color-accent);
    filter: drop-shadow(0 0 4px var(--color-accent-glow));
  }

  .srch-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    font-size: 1rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    line-height: 1.5;
    caret-color: var(--color-accent);
  }
  .srch-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .srch-kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.875rem;
    height: 1.5rem;
    padding: 0 0.5rem;
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    color: var(--color-text-tertiary);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    flex-shrink: 0;
    transition: opacity 200ms ease;
  }

  /* ==============================
     Results
     ============================== */
  .srch-results {
    flex: 1;
    overflow-y: auto;
    padding: 0.375rem;
  }
  .srch-results:empty { display: none; }

  /* ==============================
     Skeleton Loading
     ============================== */
  .srch-skeleton {
    flex: 1;
    overflow: hidden;
    padding: 0.375rem;
  }

  .srch-skeleton-line {
    height: 3.25rem;
    margin: 0.25rem 0.75rem;
    border-radius: 10px;
    background: linear-gradient(
      90deg,
      var(--color-bg-tertiary) 25%,
      var(--color-bg-secondary) 50%,
      var(--color-bg-tertiary) 75%
    );
    background-size: 200% 100%;
    animation: srch-shimmer 1.5s ease-in-out infinite;
  }

  @keyframes srch-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Hide skeleton on mobile fullscreen */
  @media (max-width: 640px) {
    .srch-skeleton-line {
      margin: 0.25rem 0;
    }
  }

  .srch-empty,
  .srch-no-results {
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
    padding: 3rem 1rem;
    margin: 0;
  }

  .srch-no-results-hint {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }
  .srch-no-results-hint a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }
  .srch-no-results-hint a:hover {
    text-decoration: underline;
  }

  /* Group header */
  .srch-group {
    padding: 0.5rem 0.75rem 0.25rem;
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: var(--font-sans);
  }
  .srch-group:first-child { padding-top: 0.375rem; }

  /* Result count badge */
  .srch-group-count {
    font-weight: 400;
    opacity: 0.6;
    margin-left: 0.375rem;
  }

  /* ==============================
     Result Item
     ============================== */
  .srch-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    margin: 0.0625rem 0;
    border-radius: 10px;
    cursor: pointer;
    text-decoration: none;
    transition: background 120ms ease, box-shadow 120ms ease;
    animation: srch-fade-in 200ms ease-out both;
  }

  @keyframes srch-fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Stagger up to 10 items */
  .srch-item:nth-child(1)  { animation-delay: 0ms; }
  .srch-item:nth-child(2)  { animation-delay: 30ms; }
  .srch-item:nth-child(3)  { animation-delay: 60ms; }
  .srch-item:nth-child(4)  { animation-delay: 90ms; }
  .srch-item:nth-child(5)  { animation-delay: 120ms; }
  .srch-item:nth-child(6)  { animation-delay: 150ms; }
  .srch-item:nth-child(7)  { animation-delay: 180ms; }
  .srch-item:nth-child(8)  { animation-delay: 210ms; }
  .srch-item:nth-child(9)  { animation-delay: 240ms; }
  .srch-item:nth-child(10) { animation-delay: 270ms; }
  .srch-item:hover,
  .srch-item.active {
    background: var(--color-accent-soft);
  }
  .srch-item.active {
    box-shadow: inset 0 0 0 1.5px var(--color-accent);
  }

  /* Type badge */
  .srch-item-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    background: var(--color-bg-tertiary);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
    transition: background 120ms ease, color 120ms ease;
  }
  .srch-item:hover .srch-item-badge,
  .srch-item.active .srch-item-badge {
    background: var(--color-accent);
    color: #fff;
  }

  .srch-item-body {
    flex: 1;
    min-width: 0;
  }

  .srch-item-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    margin-bottom: 0.0625rem;
  }
  .srch-item:hover .srch-item-title,
  .srch-item.active .srch-item-title {
    color: var(--color-accent);
  }

  .srch-item-summary {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .srch-item-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.25rem;
  }

  .srch-item-tag {
    font-size: 0.625rem;
    padding: 0.0625rem 0.375rem;
    border-radius: 4px;
    background: var(--color-bg-tertiary);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  /* Search term highlight */
  .srch-highlight {
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: 2px;
    padding: 0 0.125em;
    font-weight: 600;
  }

  /* ==============================
     Footer
     ============================== */
  .srch-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1.125rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.6875rem;
    color: var(--color-text-tertiary);
  }

  .srch-footer-hints {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .srch-footer-hints kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.125rem;
    padding: 0 0.25rem;
    font-size: 0.5625rem;
    font-family: var(--font-mono);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    margin: 0 0.125rem;
  }

  .srch-footer-brand {
    font-size: 0.625rem;
    opacity: 0.5;
  }

  /* ==============================
     Mobile
     ============================== */
  @media (max-width: 640px) {
    .srch-overlay {
      padding: 0;
      align-items: stretch;
    }
    .srch-panel {
      max-width: none;
      max-height: none;
      height: 100%;
      border-radius: 0;
      border: none;
    }
  }
</style>