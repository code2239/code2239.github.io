---
import type { FlatNode } from "../../lib/categoryTree";

interface Props {
  nodes: FlatNode[];
}

const { nodes } = Astro.props;

const rootNodes = nodes.filter(n => n.depth === 0);
const childNodes = nodes.filter(n => n.depth > 0);
const MAX_PARENTS = 5;
const hasMore = rootNodes.length > MAX_PARENTS;
---

{rootNodes.length > 0 && (
  <div>
    <p class="text-xs font-semibold text-[var(--color-text-tertiary)] uppercase tracking-wider mb-3">分类浏览</p>
    <div class="flex flex-col gap-0.5" id="category-tree">
      {rootNodes.map((node, i) => {
        const children = childNodes.filter(c => c.slug.startsWith(node.slug + "/"));
        const hasChildren = children.length > 0;
        const hidden = i >= MAX_PARENTS;
        const id = `cat-${node.slug.replace(/[\/\.]/g, "-")}`;
        return (
          <div>
            <div
              class={`cat-row${hidden ? " cat-row-hidden" : ""}`}
              data-cat-id={id}
            >
              {hasChildren && (
                <button
                  class="cat-toggle"
                  data-toggle={id}
                  aria-label="展开/收起子分类"
                >
                  <svg class="cat-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m6 4 4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              )}
              {!hasChildren && <span class="cat-toggle-placeholder"></span>}
              <a href={`/blog/category/${node.slug}`} class="sidebar-cat">
                <span class="truncate">{node.label}</span>
                <span class="sidebar-tag-count">{node.count}</span>
              </a>
            </div>
            {hasChildren && (
              <div class="cat-children" data-parent={id}>
                {children.map(child => (
                  <a
                    href={`/blog/category/${child.slug}`}
                    class="sidebar-cat sidebar-cat-child"
                    style={`padding-left: ${1.375 + (child.depth - 1) * 0.75}rem`}
                  >
                    <span class="truncate">{child.label}</span>
                    <span class="sidebar-tag-count">{child.count}</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>

    {hasMore && (
      <button id="cat-expand-btn" class="cat-expand-btn">
        <span id="cat-expand-text">展开全部 ({rootNodes.length} 个分类)</span>
        <svg id="cat-expand-arrow" class="cat-expand-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m4 6 4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    )}
  </div>
)}

<style>
  .cat-row {
    display: flex;
    align-items: stretch;
    gap: 0;
  }
  .cat-row-hidden { display: none; }
  .cat-row-hidden.expanded { display: flex; }

  .cat-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-tertiary);
    padding: 0;
    margin: 0;
    transition: color 150ms ease;
    border-radius: 4px 0 0 4px;
  }
  .cat-toggle:hover { color: var(--color-accent); }
  .cat-toggle-placeholder { width: 20px; flex-shrink: 0; }
  .cat-arrow {
    width: 12px;
    height: 12px;
    transition: transform 200ms ease;
  }
  .cat-arrow.open { transform: rotate(90deg); }

  .sidebar-cat {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.375rem 0.625rem 0.375rem 0;
    font-size: 0.8125rem;
    font-family: var(--font-sans);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 0 6px 6px 0;
    transition: background 150ms ease, color 150ms ease;
  }
  .sidebar-cat:hover { background: var(--color-bg-secondary); color: var(--color-text); }
  .sidebar-cat.active { background: var(--color-accent-soft); color: var(--color-accent); font-weight: 500; }

  .sidebar-cat-child {
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
  }

  .cat-children {
    display: none;
    flex-direction: column;
    gap: 1px;
  }
  .cat-children.open { display: flex; }

  .sidebar-tag-count {
    font-size: 0.6875rem;
    color: var(--color-text-tertiary);
    background: var(--color-bg-tertiary);
    padding: 0.0625rem 0.375rem;
    border-radius: 4px;
    min-width: 1.25rem;
    text-align: center;
    flex-shrink: 0;
  }
  .sidebar-cat.active .sidebar-tag-count { background: var(--color-accent); color: #fff; }

  .cat-expand-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.375rem 0.625rem;
    font-size: 0.75rem;
    font-family: var(--font-sans);
    color: var(--color-text-tertiary);
    background: transparent;
    border: none;
    border-top: 1px solid var(--color-border);
    margin-top: 0.25rem;
    padding-top: 0.5rem;
    cursor: pointer;
    transition: color 150ms ease;
  }
  .cat-expand-btn:hover { color: var(--color-accent); }
  .cat-expand-arrow {
    width: 14px;
    height: 14px;
    transition: transform 200ms ease;
  }
  .cat-expand-arrow.open { transform: rotate(180deg); }
</style>

<script>
  function initCategoryNav() {
    const expandBtn = document.getElementById("cat-expand-btn");
    const expandText = document.getElementById("cat-expand-text");
    const expandArrow = document.getElementById("cat-expand-arrow");
    const hiddenRows = document.querySelectorAll<HTMLElement>(".cat-row-hidden");
    let expanded = false;

    if (expandBtn) {
      expandBtn.addEventListener("click", () => {
        expanded = !expanded;
        hiddenRows.forEach(el => el.classList.toggle("expanded", expanded));
        if (expandText) expandText.textContent = expanded ? "收起" : `展开全部 (${hiddenRows.length + 5} 个分类)`;
        if (expandArrow) expandArrow.classList.toggle("open", expanded);
      });
    }

    document.querySelectorAll<HTMLButtonElement>(".cat-toggle").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = btn.getAttribute("data-toggle");
        if (!id) return;
        const children = document.querySelector<HTMLElement>(`.cat-children[data-parent="${id}"]`);
        if (children) children.classList.toggle("open");
        const arrow = btn.querySelector(".cat-arrow");
        if (arrow) arrow.classList.toggle("open");
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCategoryNav);
  } else {
    initCategoryNav();
  }
</script>
